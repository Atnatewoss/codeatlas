# ── GitHub Models (free-tier LLM) ───────────────────────────────────
# Requires a classic PAT from github.com/settings/tokens
# No scopes needed — leave all checkboxes empty.
GITHUB_TOKEN=ghp_your-token-here

# ── Per-task model overrides ────────────────────────────────────────
# All three tasks use gpt-4o-mini by default. Uncomment to customize:
# GENERATION_LLM_MODEL=gpt-4o-mini
# GENERATION_LLM_TEMPERATURE=0.7
# GENERATION_LLM_MAX_TOKENS=2048
#
# EVALUATION_LLM_MODEL=gpt-4o-mini
# EVALUATION_LLM_TEMPERATURE=0.0
# EVALUATION_LLM_MAX_TOKENS=2048
#
# SYNTHESIS_LLM_MODEL=gpt-4o-mini
# SYNTHESIS_LLM_TEMPERATURE=0.2
# SYNTHESIS_LLM_MAX_TOKENS=8192

# ── Research pipeline ───────────────────────────────────────────────
# MAX_DEPTH=3
# MAX_CHILDREN=2
# KEEP_TOP_K=5
# EXECUTION_WORKERS=4
# EVALUATION_WORKERS=2

# ── Repo cache ──────────────────────────────────────────────────────
# CODEATLAS_CACHE_DIR=
